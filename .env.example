# Aura Configuration
# Copy to .env and fill in your values

# --- Required ---
AURA_HF_TOKEN=hf_your_token_here        # HuggingFace token (for pyannote gated models)
AURA_LLM_API_KEY=sk-your-key-here       # LLM API key for knowledge extraction

# --- LLM Provider ---
AURA_LLM_PROVIDER=anthropic             # anthropic, openai, or local
AURA_LLM_MODEL=claude-sonnet-4-20250514          # Model name for the provider

# --- Database ---
AURA_DB_PASSWORD=aura_secret             # PostgreSQL password

# --- Optional tuning ---
# AURA_WHISPER_MODEL=large-v3            # Whisper model size (tiny, base, small, medium, large-v3)
# AURA_WHISPER_DEVICE=auto               # auto, cuda, cpu
# AURA_MIN_SPEAKERS=1                    # Min expected speakers per recording
# AURA_MAX_SPEAKERS=10                   # Max expected speakers per recording
# AURA_SPEAKER_MATCH_THRESHOLD=0.75      # Cosine sim threshold for speaker re-identification
# AURA_SPEAKER_CANDIDATE_THRESHOLD=0.55  # Cosine sim threshold for "maybe" matches
# AURA_VAD_THRESHOLD=0.5                 # Voice activity detection sensitivity
